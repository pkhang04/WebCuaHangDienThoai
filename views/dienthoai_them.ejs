<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

        <div class="container main-content mt-4">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/dienthoai">Quản lý điện thoại</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm sản phẩm</li>
                </ol>
            </nav>

            <!-- Notification -->
            <%- message %>

                <div class="card auth-card auth-card-lg shadow-sm border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm mới</h5>
                    </div>
                    <div class="card-body p-4">
                        <form action="/dienthoai/them" method="POST" enctype="multipart/form-data"
                            class="needs-validation" novalidate>
                            <div class="row g-3">
                                <div class="col-md-6 text-start">
                                    <label for="MaDanhMuc" class="form-label fw-semibold">Danh mục</label>
                                    <select class="form-select" id="MaDanhMuc" name="MaDanhMuc" required>
                                        <option value="" disabled selected>-- Chọn danh mục --</option>
                                        <% danhmuc.forEach(item=> { %>
                                            <option value="<%= item._id %>">
                                                <%= item.TenDanhMuc %>
                                            </option>
                                            <% }) %>
                                    </select>
                                    <div class="invalid-feedback">Vui lòng chọn danh mục.</div>
                                </div>

                                <div class="col-md-6 text-start">
                                    <label for="TenDT" class="form-label fw-semibold">Tên điện thoại</label>
                                    <input type="text" class="form-control" id="TenDT" name="TenDT"
                                        placeholder="Nhập tên sản phẩm" required>
                                    <div class="invalid-feedback">Vui lòng nhập tên điện thoại.</div>
                                </div>

                                <div class="col-md-4 text-start">
                                    <label for="GiaGoc" class="form-label fw-semibold">Giá gốc (đ)</label>
                                    <input type="number" class="form-control" id="GiaGoc" name="GiaGoc" value="0"
                                        min="0" required>
                                </div>

                                <div class="col-md-4 text-start">
                                    <label for="GiaBan" class="form-label fw-semibold">Giá bán (đ)</label>
                                    <input type="number" class="form-control" id="GiaBan" name="GiaBan" value="0"
                                        min="0" required>
                                </div>

                                <div class="col-md-4 text-start">
                                    <label for="SoLuong" class="form-label fw-semibold">Số lượng tồn</label>
                                    <input type="number" class="form-control" id="SoLuong" name="SoLuong" value="0"
                                        min="0" required>
                                </div>

                                <div class="col-md-12 text-start">
                                    <label for="HinhAnh" class="form-label fw-semibold">Ảnh sản phẩm</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-image"></i></span>
                                        <input type="file" class="form-control" id="HinhAnh" name="HinhAnh"
                                            accept="image/*">
                                    </div>
                                    <div class="form-text">Chọn tệp hình ảnh để tải lên (Để trống sẽ dùng ảnh mặc định).
                                    </div>
                                </div>

                                <div class="col-md-6 text-start">
                                    <label for="LuotXem" class="form-label fw-semibold">Lượt xem</label>
                                    <input type="number" class="form-control" id="LuotXem" name="LuotXem" value="0"
                                        min="0">
                                </div>

                                <div class="col-md-6 text-start">
                                    <label for="LuotMua" class="form-label fw-semibold">Lượt mua</label>
                                    <input type="number" class="form-control" id="LuotMua" name="LuotMua" value="0"
                                        min="0">
                                </div>

                                <div class="col-md-12 text-start">
                                    <label for="MoTa" class="form-label fw-semibold">Mô tả sản phẩm</label>
                                    <textarea class="form-control" id="MoTa" name="MoTa" rows="4"
                                        placeholder="Nhập mô tả chi tiết..."></textarea>
                                </div>
                            </div>

                            <hr class="my-4">

                            <div class="d-flex justify-content-end gap-2">
                                <a href="/dienthoai" class="btn btn-light px-4">Hủy bỏ</a>
                                <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                    <i class="bi bi-cloud-upload me-2"></i>Lưu sản phẩm
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
        </div>

        <!-- Footer Section -->
        <%- include('footer') %>

            <!-- Javascript Section -->
            <%- include('javascript') %>

                <script>
                    (() => {
                        'use strict';
                        const forms = document.querySelectorAll('.needs-validation');
                        Array.from(forms).forEach(form => {
                            form.addEventListener('submit', event => {
                                if (!form.checkValidity()) {
                                    event.preventDefault();
                                    event.stopPropagation();
                                }
                                form.classList.add('was-validated');
                            }, false);
                        });
                    })();
                </script>
</body>

</html>