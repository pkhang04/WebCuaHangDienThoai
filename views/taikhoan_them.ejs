<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

        <div class="container main-content mt-4">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/taikhoan">Quản lý tài khoản</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
                </ol>
            </nav>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-bold text-dark">
                                <i class="bi bi-person-plus-fill me-2 text-primary"></i>Thêm mới tài khoản
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <form action="/taikhoan/them" method="POST" enctype="multipart/form-data"
                                class="needs-validation" novalidate>
                                <div class="row g-3">
                                    <div class="col-md-6 text-start">
                                        <label for="HoVaTen" class="form-label fw-semibold">Họ và tên</label>
                                        <input type="text" class="form-control" id="HoVaTen" name="HoVaTen"
                                            placeholder="Nhập họ và tên đầy đủ" required>
                                        <div class="invalid-feedback">Vui lòng nhập họ và tên.</div>
                                    </div>
                                    <div class="col-md-6 text-start">
                                        <label for="Email" class="form-label fw-semibold">Email</label>
                                        <input type="email" class="form-control" id="Email" name="Email"
                                            placeholder="example@email.com">
                                        <div class="invalid-feedback">Vui lòng nhập email hợp lệ.</div>
                                    </div>
                                    <div class="col-12 text-start">
                                        <label for="HinhAnh" class="form-label fw-semibold">Ảnh đại diện</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="bi bi-image"></i></span>
                                            <input type="file" class="form-control" id="HinhAnh" name="HinhAnh"
                                                accept="image/*">
                                        </div>
                                        <div class="form-text">Chọn tệp hình ảnh để tải lên (Để trống sẽ dùng ảnh mặc
                                            định user.jpg).</div>
                                    </div>
                                    <div class="col-12 text-start">
                                        <label for="TenDangNhap" class="form-label fw-semibold">Tên đăng nhập</label>
                                        <input type="text" class="form-control" id="TenDangNhap" name="TenDangNhap"
                                            placeholder="Sử dụng làm tên đăng nhập" required>
                                        <div class="invalid-feedback">Vui lòng nhập tên đăng nhập.</div>
                                    </div>
                                    <div class="col-md-6 text-start">
                                        <label for="MatKhau" class="form-label fw-semibold">Mật khẩu</label>
                                        <input type="password" class="form-control" id="MatKhau" name="MatKhau"
                                            placeholder="Nhập mật khẩu an toàn" required>
                                        <div class="invalid-feedback">Vui lòng nhập mật khẩu.</div>
                                    </div>
                                    <div class="col-md-6 text-start">
                                        <label for="XacNhanMatKhau" class="form-label fw-semibold">Xác nhận mật
                                            khẩu</label>
                                        <input type="password" class="form-control" id="XacNhanMatKhau"
                                            name="XacNhanMatKhau" placeholder="Nhập lại mật khẩu" required>
                                        <div class="invalid-feedback">Vui lòng xác nhận mật khẩu.</div>
                                    </div>
                                </div>

                                <hr class="my-4 opacity-50">

                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="/taikhoan" class="btn btn-light px-4 rounded-pill">
                                        Hủy bỏ
                                    </a>
                                    <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm">
                                        <i class="bi bi-person-check-fill me-2"></i>Tạo tài khoản
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Section -->
        <%- include('footer') %>

            <!-- Javascript Section -->
            <%- include('javascript') %>

                <script>
                    (() => {
                        'use strict';
                        const forms = document.querySelectorAll('.needs-validation');
                        Array.from(forms).forEach(form => {
                            form.addEventListener('submit', event => {
                                const password = document.getElementById('MatKhau');
                                const confirmPassword = document.getElementById('XacNhanMatKhau');

                                if (!form.checkValidity() || (password && confirmPassword && password.value !== confirmPassword.value)) {
                                    event.preventDefault();
                                    event.stopPropagation();

                                    if (password && confirmPassword && password.value !== confirmPassword.value) {
                                        confirmPassword.setCustomValidity('Mật khẩu không trùng khớp.');
                                        const feedback = confirmPassword.nextElementSibling;
                                        if (feedback && feedback.classList.contains('invalid-feedback')) {
                                            feedback.textContent = 'Mật khẩu xác nhận không trùng khớp.';
                                        }
                                    } else {
                                        confirmPassword.setCustomValidity('');
                                    }
                                }
                                form.classList.add('was-validated');
                            }, false);
                        });
                    })();
                </script>

</body>

</html>