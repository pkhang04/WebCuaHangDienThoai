<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

        <div class="container main-content mt-4">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/taikhoan">Quản lý tài khoản</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
                </ol>
            </nav>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-bold text-dark">
                                <i class="bi bi-pencil-square me-2 text-warning"></i>Cập nhật thông tin tài khoản
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            <form action="/taikhoan/sua/<%= taikhoan._id %>" method="POST" enctype="multipart/form-data"
                                class="needs-validation" novalidate>
                                <div class="row g-3">
                                    <div class="col-md-6 text-start">
                                        <label for="HoVaTen" class="form-label fw-semibold">Họ và tên</label>
                                        <input type="text" class="form-control" id="HoVaTen" name="HoVaTen"
                                            value="<%= taikhoan.HoVaTen %>" required>
                                        <div class="invalid-feedback">Vui lòng nhập họ và tên.</div>
                                    </div>
                                    <div class="col-md-6 text-start">
                                        <label for="Email" class="form-label fw-semibold">Email</label>
                                        <input type="email" class="form-control" id="Email" name="Email"
                                            value="<%= taikhoan.Email %>">
                                        <div class="invalid-feedback">Vui lòng nhập email hợp lệ.</div>
                                    </div>
                                    <div class="col-12 text-start">
                                        <label for="HinhAnh" class="form-label fw-semibold">Ảnh đại diện</label>
                                        <div class="row align-items-center">
                                            <div class="col-md-9">
                                                <div class="input-group">
                                                    <span class="input-group-text"><i class="bi bi-image"></i></span>
                                                    <input type="file" class="form-control" id="HinhAnh" name="HinhAnh"
                                                        accept="image/*">
                                                </div>
                                                <div class="form-text">Chọn tệp hình ảnh để tải lên (Để trống sẽ giữ
                                                    nguyên ảnh cũ).</div>
                                            </div>
                                            <div class="col-md-3 text-center">
                                                <img src="<%= taikhoan.HinhAnh ? (taikhoan.HinhAnh.startsWith('http') ? taikhoan.HinhAnh : '/images/icons/' + taikhoan.HinhAnh) : '/images/icons/user.jpg' %>"
                                                    id="img-preview" class="rounded-circle shadow-sm" alt="Preview"
                                                    style="max-height: 80px; width: 80px; object-fit: cover;">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 text-start">
                                        <label for="TenDangNhap" class="form-label fw-semibold">Tên đăng nhập</label>
                                        <input type="text" class="form-control" id="TenDangNhap" name="TenDangNhap"
                                            value="<%= taikhoan.TenDangNhap %>" required>
                                        <div class="invalid-feedback">Vui lòng nhập tên đăng nhập.</div>
                                    </div>

                                    <div class="col-md-6 text-start">
                                        <label for="QuyenHan" class="form-label fw-semibold">Phân quyền</label>
                                        <select class="form-select" id="QuyenHan" name="QuyenHan" required>
                                            <option value="quantrivien" <%=taikhoan.QuyenHan==='quantrivien'
                                                ? 'selected' : '' %>>Quản trị viên</option>
                                            <option value="nhanvien" <%=taikhoan.QuyenHan==='nhanvien' ? 'selected' : ''
                                                %>>Nhân viên</option>
                                            <option value="khachhang" <%=taikhoan.QuyenHan==='khachhang' ? 'selected'
                                                : '' %>>Khách hàng</option>
                                        </select>
                                        <div class="invalid-feedback">Vui lòng chọn quyền hạn.</div>
                                    </div>

                                    <div class="col-md-6 text-start">
                                        <label class="form-label fw-semibold">Trạng thái kích hoạt</label>
                                        <div class="d-flex gap-4 mt-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="KichHoat"
                                                    id="KichHoat1" value="1" <%=taikhoan.KichHoat==1 ? "checked" : "" %>
                                                required>
                                                <label class="form-check-label" for="KichHoat1">Kích hoạt</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="KichHoat"
                                                    id="KichHoat0" value="0" <%=taikhoan.KichHoat==0 ? "checked" : "" %>
                                                required>
                                                <label class="form-check-label" for="KichHoat0">Khóa tài khoản</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6 text-start border-top pt-3">
                                        <label for="MatKhau" class="form-label fw-semibold">Mật khẩu mới</label>
                                        <input type="password" class="form-control" id="MatKhau" name="MatKhau"
                                            placeholder="********">
                                        <span class="d-block small text-primary mt-1">Bỏ trống nếu muốn giữ nguyên mật
                                            khẩu cũ.</span>
                                    </div>
                                    <div class="col-md-6 text-start border-top pt-3">
                                        <label for="XacNhanMatKhau" class="form-label fw-semibold">Xác nhận mật khẩu
                                            mới</label>
                                        <input type="password" class="form-control" id="XacNhanMatKhau"
                                            name="XacNhanMatKhau" placeholder="********">
                                        <span class="d-block small text-primary mt-1">Bỏ trống nếu muốn giữ nguyên mật
                                            khẩu cũ.</span>
                                    </div>
                                </div>

                                <hr class="my-4 opacity-50">

                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="/taikhoan" class="btn btn-light px-4 rounded-pill">
                                        Quay lại
                                    </a>
                                    <button type="submit" class="btn btn-warning px-4 rounded-pill shadow-sm">
                                        <i class="bi bi-save-fill me-2"></i>Cập nhật tài khoản
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Section -->
        <%- include('footer') %>

            <!-- Javascript Section -->
            <%- include('javascript') %>

                <script>
                    (() => {
                        'use strict';
                        const forms = document.querySelectorAll('.needs-validation');
                        Array.from(forms).forEach(form => {
                            form.addEventListener('submit', event => {
                                const password = document.getElementById('MatKhau');
                                const confirmPassword = document.getElementById('XacNhanMatKhau');

                                let passwordsMatch = true;
                                if (password && confirmPassword && password.value !== '') {
                                    if (password.value !== confirmPassword.value) {
                                        passwordsMatch = false;
                                        confirmPassword.setCustomValidity('Mật khẩu không trùng khớp.');
                                        const feedback = confirmPassword.nextElementSibling;
                                        // Small spans are between input and potential feedback if not careful
                                        const feedbacks = confirmPassword.parentElement.querySelectorAll('.invalid-feedback');
                                        if (feedbacks.length === 0) {
                                            const div = document.createElement('div');
                                            div.classList.add('invalid-feedback');
                                            div.textContent = 'Mật khẩu xác nhận không trùng khớp.';
                                            confirmPassword.parentElement.appendChild(div);
                                        } else {
                                            feedbacks[0].textContent = 'Mật khẩu xác nhận không trùng khớp.';
                                        }
                                    } else {
                                        confirmPassword.setCustomValidity('');
                                    }
                                } else {
                                    confirmPassword.setCustomValidity('');
                                }

                                if (!form.checkValidity() || !passwordsMatch) {
                                    event.preventDefault();
                                    event.stopPropagation();
                                }
                                form.classList.add('was-validated');
                            }, false);
                        });

                        const hinhAnhInput = document.getElementById('HinhAnh');
                        const imgPreview = document.getElementById('img-preview');
                        if (hinhAnhInput && imgPreview) {
                            hinhAnhInput.addEventListener('change', function () {
                                const file = this.files[0];
                                if (file) {
                                    const reader = new FileReader();
                                    reader.onload = function (e) {
                                        imgPreview.src = e.target.result;
                                    };
                                    reader.readAsDataURL(file);
                                }
                            });
                        }
                    })();
                </script>

</body>

</html>