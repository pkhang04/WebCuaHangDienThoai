<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

    <div class="container main-content mt-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Quản lý tài khoản</li>
            </ol>
        </nav>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-people-fill me-2"></i>Danh sách tài khoản</h5>
                <a href="/taikhoan/them" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-person-plus-fill me-2"></i>Thêm tài khoản
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="table-light text-muted">
                            <tr>
                                <th style="width: 60px;">STT</th>
                                <th class="text-start">Họ và tên</th>
                                <th>Email</th>
                                <th>Ảnh</th>
                                <th>Username</th>
                                <th>Quyền</th>
                                <th>Trạng thái</th>
                                <th style="width: 150px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (taikhoan.length > 0) { %>
                                <% taikhoan.forEach((item, index) => { %>
                                    <tr>
                                        <td class="fw-bold text-muted"><%= index + 1 %></td>
                                        <td class="text-start">
                                            <div class="fw-bold"><%= item.HoVaTen %></div>
                                        </td>
                                        <td><%= item.Email %></td>
                                        <td>
                                            <img src="<%= item.HinhAnh ? (item.HinhAnh.startsWith('http') ? item.HinhAnh : '/images/icons/' + item.HinhAnh) : '/images/icons/user.jpg' %>" 
                                                 alt="Avatar" class="avatar-circle">
                                        </td>
                                        <td><code class="text-primary fw-bold"><%= item.TenDangNhap %></code></td>
                                        <td>
                                            <% if (item.QuyenHan === 'quantrivien') { %>
                                                <span class="badge bg-danger rounded-pill px-3">Quản trị</span>
                                            <% } else if (item.QuyenHan === 'nhanvien') { %>
                                                <span class="badge bg-warning text-dark rounded-pill px-3">Nhân viên</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary rounded-pill px-3">Khách hàng</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (item.KichHoat === 1) { %>
                                                <span class="text-success" title="Đang hoạt động"><i class="bi bi-check-circle-fill"></i></span>
                                            <% } else { %>
                                                <span class="text-danger" title="Bị khóa"><i class="bi bi-x-circle-fill"></i></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <a href="/taikhoan/sua/<%= item._id %>" class="btn btn-sm btn-outline-warning" title="Chỉnh sửa">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <a href="/taikhoan/xoa/<%= item._id %>" class="btn btn-sm btn-outline-danger" 
                                                   onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?')" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted">
                                        <i class="bi bi-person-x fs-1 d-block mb-3 opacity-25"></i>
                                        Chưa có tài khoản nào trong hệ thống.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-muted small py-3 px-4">
                Tổng cộng: <strong><%= taikhoan.length %></strong> tài khoản.
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <%- include('footer') %>

    <!-- Javascript Section -->
    <%- include('javascript') %>

</body>

</html>
