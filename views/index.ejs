<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <!-- Navbar Section -->
    <%- include('navbar') %>

    <!-- Carousel Banner -->
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/banners/banner01.png" class="d-block w-100" alt="Sự kiện 1" style="height: auto; max-height: 450px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="/images/banners/banner02.png" class="d-block w-100" alt="Sự kiện 2" style="height: auto; max-height: 450px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="/images/banners/banner03.png" class="d-block w-100" alt="Sự kiện 3" style="height: auto; max-height: 450px; object-fit: cover;">
            </div>
            <div class="carousel-item">
                <img src="/images/banners/banner04.png" class="d-block w-100" alt="Sự kiện 4" style="height: auto; max-height: 450px; object-fit: cover;">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <!-- Notification -->
    <div class="container mt-3">
        <%- message %>
    </div>

    <!-- Danh sách sản phẩm theo danh mục -->
    <div class="container main-content mt-4 mb-5">
        <% danhmucs.forEach(dm => { 
            // Lọc các bản ghi thuộc danh mục hiện tại
            const dsTheoDanhMuc = dienthoais.filter(dt => dt.DanhMuc && dt.DanhMuc._id.toString() === dm._id.toString());
            if (dsTheoDanhMuc.length > 0) {
        %>
            <div class="mb-5">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
                    <h2 class="text-uppercase fw-bold text-dark mb-0 border-start border-4 border-primary ps-3"><%= dm.TenDanhMuc %></h2>
                    <a href="/timkiem?q=<%= dm.TenDanhMuc %>" class="text-decoration-none text-primary fs-6 fw-semibold">Xem tất cả <i class="bi bi-chevron-right"></i></a>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 w-100 mx-0">
                    <% dsTheoDanhMuc.slice(0, 4).forEach(item => { %>
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm hover-elevate product-card">
                                <!-- Badge Giảm Giá / Hết hàng -->
                                <div class="position-absolute top-0 end-0 mt-3 me-3 z-2">
                                    <% if (item.SoLuong <= 0) { %>
                                        <span class="badge bg-secondary px-3 py-2 fs-6 shadow-sm">Hết hàng</span>
                                    <% } else if (item.GiaGoc > item.GiaBan) { 
                                        const percent = Math.round(((item.GiaGoc - item.GiaBan) / item.GiaGoc) * 100);
                                    %>
                                        <span class="badge bg-danger px-2 py-1 fs-6 shadow-sm">Giảm <%= percent %>%</span>
                                    <% } %>
                                </div>
                                
                                <div class="px-3 pt-4 text-center pb-2 product-img-box">
                                    <a href="/sanpham/<%= item._id %>">
                                        <img src="<%= item.HinhAnh ? (item.HinhAnh.startsWith('http') || item.HinhAnh.startsWith('/') ? item.HinhAnh : '/images/products/' + item.HinhAnh) : '/images/icons/product.jpg' %>" 
                                             class="card-img-top img-fluid" alt="<%= item.TenDT %>" style="max-height: 220px; object-fit: contain;">
                                    </a>
                                </div>
                                <div class="card-body d-flex flex-column px-4">
                                    <h5 class="card-title text-truncate fw-bold mb-2">
                                        <a href="/sanpham/<%= item._id %>" class="text-dark text-decoration-none hover-primary"><%= item.TenDT %></a>
                                    </h5>
                                    
                                    <div class="mt-auto">
                                        <div class="mb-3">
                                            <div class="fs-5 fw-bold text-danger price-text"><%= item.GiaBan.toLocaleString('vi-VN') %>đ</div>
                                            <% if (item.GiaGoc > item.GiaBan) { %>
                                                <small class="text-decoration-line-through text-muted d-block"><%= item.GiaGoc.toLocaleString('vi-VN') %>đ</small>
                                            <% } else { %>
                                                <small class="text-muted d-block opacity-0">0đ</small>
                                            <% } %>
                                        </div>
                                        <div class="d-grid gap-2">
                                            <% if (item.SoLuong > 0) { %>
                                                <form action="/giohang/them/<%= item._id %>" method="POST" class="d-grid">
                                                    <input type="hidden" name="SoLuong" value="1">
                                                    <button type="submit" class="btn btn-outline-primary fw-semibold rounded-pill">
                                                        <i class="bi bi-cart-plus me-1"></i>Thêm vào giỏ
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <button class="btn btn-outline-secondary fw-semibold rounded-pill" disabled>
                                                    <i class="bi bi-telephone me-1"></i>Liên hệ
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% 
            }
        }); 
        %>
    </div>

    <!-- Footer Section -->
    <%- include('footer') %>

    <!-- Javascript Section -->
    <%- include('javascript') %>

</body>

</html>