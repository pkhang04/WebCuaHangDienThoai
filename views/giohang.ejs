<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/giohang.css">
</head>
<body class="bg-light">

    <!-- Navbar Section -->
    <%- include('navbar') %>

    <!-- Notification -->
    <div class="container mt-3" id="alert-container">
        <%- message %>
    </div>

    <div class="container main-content mt-4 mb-5">
        <h2 class="fw-bold mb-4 border-start border-4 border-primary ps-3 fs-4">Giỏ hàng của bạn</h2>

        <% if (giohang && giohang.length > 0) { %>
            <div class="row g-3">
                <!-- Danh sách sản phẩm -->
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0 root-card">
                        <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="selectAll" <%= giohang.every(i => i.isSelected) ? 'checked' : '' %>>
                                <label class="form-check-label fw-bold small" for="selectAll">Chọn tất cả (<%= giohang.length %>)</label>
                            </div>
                            <a href="/giohang/xoatatca" class="text-danger text-decoration-none x-small" onclick="return confirm('Bạn muốn dọn sạch giỏ hàng?')">
                                <i class="bi bi-trash me-1"></i>Xóa tất cả
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                <% giohang.forEach((item, index) => { %>
                                    <div class="list-group-item p-3 product-item" data-id="<%= item._id %>" data-price="<%= item.GiaBan %>">
                                        <div class="d-flex align-items-center gap-3">
                                            <!-- Checkbox -->
                                            <div class="form-check mb-0">
                                                <input class="form-check-input item-checkbox" type="checkbox" value="<%= item._id %>" <%= item.isSelected ? 'checked' : '' %>>
                                            </div>
                                            
                                            <!-- Image -->
                                            <div class="flex-shrink-0" style="width: 60px;">
                                                <img src="<%= item.HinhAnh ? (item.HinhAnh.startsWith('http') || item.HinhAnh.startsWith('/') ? item.HinhAnh : '/images/products/' + item.HinhAnh) : '/images/icons/product.jpg' %>" 
                                                     alt="" class="img-fluid rounded">
                                            </div>

                                            <!-- Info -->
                                            <div class="flex-grow-1 min-width-0">
                                                <h6 class="fw-bold mb-0 product-name text-truncate"><%= item.TenDT %></h6>
                                                <div class="text-danger fw-semibold item-price-display"><%= item.GiaBan.toLocaleString('vi-VN') %>đ</div>
                                                <small class="text-muted x-small">Kho: <%= item.TonKho %></small>
                                            </div>

                                            <!-- Quantity -->
                                            <div class="flex-shrink-0">
                                                <div class="input-group input-group-sm" style="width: 100px;">
                                                    <button class="btn btn-outline-secondary btn-minus px-2" type="button">-</button>
                                                    <input type="number" class="form-control text-center quantity-input border-secondary-subtle" value="<%= item.SoLuongMua %>" min="1" max="<%= item.TonKho %>">
                                                    <button class="btn btn-outline-secondary btn-plus px-2" type="button">+</button>
                                                </div>
                                            </div>

                                            <!-- Total & Delete -->
                                            <div class="flex-shrink-0 text-end" style="min-width: 120px;">
                                                <div class="fw-bold text-dark item-total mb-1">
                                                    <%= (item.GiaBan * item.SoLuongMua).toLocaleString('vi-VN') %>đ
                                                </div>
                                                <a href="/giohang/xoa/<%= index %>" class="text-danger text-decoration-none small" title="Xóa">
                                                    <i class="bi bi-trash3"></i> Xóa
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Đặt hàng thanh toán -->
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 sticky-lg-top root-card" style="top: 20px; z-index: 1;">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-3">Thông Tin Nhận Hàng</h6>
                            <form action="/donhang/dathang" method="POST" class="needs-validation" id="checkoutForm" novalidate>
                                <input type="hidden" name="selectedItems" id="selectedItemsInput">
                                
                                <div class="mb-2">
                                    <label for="TenNguoiNhan" class="form-label text-muted x-small mb-1">Người nhận</label>
                                    <input type="text" class="form-control form-control-sm" id="TenNguoiNhan" name="TenNguoiNhan" value="<%= session.HoVaTen %>" required>
                                </div>
                                <div class="mb-2">
                                    <label for="DienThoai" class="form-label text-muted x-small mb-1">Số điện thoại</label>
                                    <input type="tel" class="form-control form-control-sm" id="DienThoai" name="DienThoai" required>
                                </div>
                                <div class="mb-2">
                                    <label for="DiaChi" class="form-label text-muted x-small mb-1">Địa chỉ giao hàng</label>
                                    <textarea class="form-control form-control-sm" id="DiaChi" name="DiaChi" rows="2" required></textarea>
                                </div>
                                <div class="mb-3">
                                    <label for="GhiChu" class="form-label text-muted x-small mb-1">Ghi chú</label>
                                    <input type="text" class="form-control form-control-sm" id="GhiChu" name="GhiChu">
                                </div>
                                
                                <hr class="my-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Tổng (<span id="selectedCount">0</span> SP)</span>
                                    <span class="fw-bold text-danger" id="grandTotal">0₫</span>
                                </div>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-warning fw-bold py-2 shadow-sm" id="btnCheckout" disabled>ĐẶT HÀNG NGAY</button>
                                </div>
                                <div class="text-center mt-2"><small class="text-muted x-small"><i class="bi bi-shield-check me-1"></i>Thanh toán khi nhận hàng</small></div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-5 bg-white rounded-3 shadow-sm">
                <i class="bi bi-cart-x fs-1 text-muted opacity-25 d-block mb-3"></i>
                <h4 class="text-muted mb-4">Giỏ hàng trống!</h4>
                <a href="/" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold"><i class="bi bi-arrow-left me-2"></i>Mua sắm ngay</a>
            </div>
        <% } %>
    </div>

    <!-- Footer Section -->
    <%- include('footer') %>

    <!-- Javascript Section -->
    <%- include('javascript') %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const productItems = document.querySelectorAll('.product-item');
            const selectAllCheckbox = document.getElementById('selectAll');
            const itemCheckboxes = document.querySelectorAll('.item-checkbox');
            const grandTotalDisplay = document.getElementById('grandTotal');
            const selectedCountDisplay = document.getElementById('selectedCount');
            const btnCheckout = document.getElementById('btnCheckout');
            const selectedItemsInput = document.getElementById('selectedItemsInput');

            function formatCurrency(number) {
                return new Intl.NumberFormat('vi-VN').format(number) + 'đ';
            }

            function updateTotals() {
                let total = 0;
                let count = 0;
                const selectedItems = [];

                productItems.forEach(item => {
                    const checkbox = item.querySelector('.item-checkbox');
                    if (checkbox.checked) {
                        const price = parseInt(item.getAttribute('data-price'));
                        const quantity = parseInt(item.querySelector('.quantity-input').value) || 0;
                        const subtotal = price * quantity;
                        
                        item.querySelector('.item-total').textContent = formatCurrency(subtotal);
                        total += subtotal;
                        count++;
                        
                        selectedItems.push({
                            id: item.getAttribute('data-id'),
                            quantity: quantity
                        });
                    }
                });

                if (grandTotalDisplay) grandTotalDisplay.textContent = formatCurrency(total);
                if (selectedCountDisplay) selectedCountDisplay.textContent = count;
                if (selectedItemsInput) selectedItemsInput.value = JSON.stringify(selectedItems);
                
                if (btnCheckout) {
                    btnCheckout.disabled = count === 0;
                }
                
                // Update selectAll status
                if (selectAllCheckbox) {
                    const allChecked = Array.from(itemCheckboxes).every(cb => cb.checked);
                    selectAllCheckbox.checked = allChecked;
                }
            }

            async function updateCartAjax(productId, quantity, isSelected) {
                try {
                    await fetch('/giohang/capnhat-ajax', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId, quantity, isSelected })
                    });
                } catch (error) { console.error('Lỗi sync:', error); }
            }

            productItems.forEach(item => {
                const btnMinus = item.querySelector('.btn-minus');
                const btnPlus = item.querySelector('.btn-plus');
                const input = item.querySelector('.quantity-input');
                const checkbox = item.querySelector('.item-checkbox');
                const productId = item.getAttribute('data-id');

                btnMinus.addEventListener('click', function() {
                    if (input.value > 1) {
                        input.stepDown();
                        updateTotals();
                        updateCartAjax(productId, input.value, checkbox.checked);
                    }
                });

                btnPlus.addEventListener('click', function() {
                    const max = parseInt(input.getAttribute('max'));
                    if (input.value < max) {
                        input.stepUp();
                        updateTotals();
                        updateCartAjax(productId, input.value, checkbox.checked);
                    }
                });

                input.addEventListener('change', function() {
                    const max = parseInt(input.getAttribute('max'));
                    let val = parseInt(input.value);
                    if (isNaN(val) || val < 1) val = 1;
                    if (val > max) val = max;
                    input.value = val;
                    updateTotals();
                    updateCartAjax(productId, input.value, checkbox.checked);
                });

                checkbox.addEventListener('change', function() {
                    updateTotals();
                    updateCartAjax(productId, input.value, checkbox.checked);
                });
            });

            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    const isChecked = this.checked;
                    itemCheckboxes.forEach(cb => {
                        cb.checked = isChecked;
                        const productId = cb.closest('.product-item').getAttribute('data-id');
                        const quantity = cb.closest('.product-item').querySelector('.quantity-input').value;
                        updateCartAjax(productId, quantity, isChecked);
                    });
                    updateTotals();
                });
            }

            updateTotals();

            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        });
    </script>
</body>
</html>
