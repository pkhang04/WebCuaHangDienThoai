<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

        <div class="container main-content mt-4">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Quản lý điện thoại</li>
                </ol>
            </nav>

            <!-- Notification -->
            <%- message %>

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-phone-fill me-2 text-primary"></i>Danh sách
                            điện thoại</h5>
                        <a href="/dienthoai/them" class="btn btn-primary rounded-pill px-4 shadow-sm">
                            <i class="bi bi-plus-circle-fill me-2"></i>Thêm sản phẩm
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 text-center">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th style="width: 50px;">#</th>
                                        <th>Ảnh</th>
                                        <th class="text-start">Tên sản phẩm</th>
                                        <th>Danh mục</th>
                                        <th>Giá bán</th>
                                        <th>Tồn kho</th>
                                        <th>Thống kê</th>
                                        <th style="width: 130px;">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (dienthoai.length> 0) { %>
                                        <% dienthoai.forEach((item, index)=> { %>
                                            <tr>
                                                <td class="text-muted">
                                                    <%= index + 1 %>
                                                </td>
                                                <td>
                                                    <img src="<%= item.HinhAnh ? (item.HinhAnh.startsWith('http') || item.HinhAnh.startsWith('/') ? item.HinhAnh : '/images/products/' + item.HinhAnh) : '/images/icons/product.jpg' %>"
                                                        alt="Product" class="product-img shadow-sm">
                                                </td>
                                                <td class="text-start">
                                                    <div class="fw-bold text-dark">
                                                        <%= item.TenDT %>
                                                    </div>
                                                    <small class="text-muted">Người đăng: <%= item.TaiKhoan ?
                                                            item.TaiKhoan.HoVaTen : 'Hệ thống' %></small>
                                                </td>
                                                <td>
                                                    <span
                                                        class="badge bg-info-subtle text-info border border-info-subtle px-3">
                                                        <%= item.DanhMuc ? item.DanhMuc.TenDanhMuc : 'N/A' %>
                                                    </span>
                                                </td>
                                                <td><span class="price-text">
                                                        <%= item.GiaBan.toLocaleString() %>đ
                                                    </span></td>
                                                <td>
                                                    <% if (item.SoLuong <=5) { %>
                                                        <span class="text-danger fw-bold">
                                                            <%= item.SoLuong %>
                                                        </span>
                                                        <% } else { %>
                                                            <span class="text-success fw-bold">
                                                                <%= item.SoLuong %>
                                                            </span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <div class="stats-badge text-muted">
                                                        <span><i class="bi bi-eye me-1"></i>
                                                            <%= item.LuotXem %>
                                                        </span> |
                                                        <span><i class="bi bi-cart-check me-1"></i>
                                                            <%= item.LuotMua %>
                                                        </span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="btn-group">
                                                        <a href="/dienthoai/sua/<%= item._id %>"
                                                            class="btn btn-sm btn-outline-warning" title="Sửa">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </a>
                                                        <a href="/dienthoai/xoa/<%= item._id %>"
                                                            class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')"
                                                            title="Xóa">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="8" class="text-center py-5 text-muted">
                                                            <i
                                                                class="bi bi-phone-vibrate fs-1 d-block mb-3 opacity-25"></i>
                                                            Chưa có sản phẩm điện thoại nào.
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white text-muted small py-3 px-4">
                        Tổng cộng: <strong>
                            <%= dienthoai.length %>
                        </strong> sản phẩm hiện có.
                    </div>
                </div>
        </div>

        <!-- Footer Section -->
        <%- include('footer') %>

            <!-- Javascript Section -->
            <%- include('javascript') %>

</body>

</html>