<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Navbar Section -->
    <%- include('navbar') %>

    <div class="container main-content mt-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/dienthoai">Quản lý điện thoại</a></li>
                <li class="breadcrumb-item active" aria-current="page">Sửa sản phẩm</li>
            </ol>
        </nav>

        <!-- Notification -->
        <%- message %>

        <div class="card auth-card auth-card-lg shadow-sm border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Sửa thông tin sản phẩm</h5>
            </div>
            <div class="card-body p-4">
                <form action="/dienthoai/sua/<%= dienthoai._id %>" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6 text-start">
                            <label for="MaDanhMuc" class="form-label fw-semibold">Danh mục</label>
                            <select class="form-select" id="MaDanhMuc" name="MaDanhMuc" required>
                                <% danhmuc.forEach(item => { %>
                                    <option value="<%= item._id %>" <%= item._id.toString() === dienthoai.DanhMuc.toString() ? 'selected' : '' %>>
                                        <%= item.TenDanhMuc %>
                                    </option>
                                <% }) %>
                            </select>
                            <div class="invalid-feedback">Vui lòng chọn danh mục.</div>
                        </div>

                        <div class="col-md-6 text-start">
                            <label for="TenDT" class="form-label fw-semibold">Tên điện thoại</label>
                            <input type="text" class="form-control" id="TenDT" name="TenDT" value="<%= dienthoai.TenDT %>" required>
                            <div class="invalid-feedback">Vui lòng nhập tên điện thoại.</div>
                        </div>

                        <div class="col-md-4 text-start">
                            <label for="GiaGoc" class="form-label fw-semibold">Giá gốc (đ)</label>
                            <input type="number" class="form-control" id="GiaGoc" name="GiaGoc" value="<%= dienthoai.GiaGoc %>" min="0" required>
                        </div>

                        <div class="col-md-4 text-start">
                            <label for="GiaBan" class="form-label fw-semibold">Giá bán (đ)</label>
                            <input type="number" class="form-control" id="GiaBan" name="GiaBan" value="<%= dienthoai.GiaBan %>" min="0" required>
                        </div>

                        <div class="col-md-4 text-start">
                            <label for="SoLuong" class="form-label fw-semibold">Số lượng tồn</label>
                            <input type="number" class="form-control" id="SoLuong" name="SoLuong" value="<%= dienthoai.SoLuong %>" min="0" required>
                        </div>

                        <div class="col-md-12 text-start">
                            <label for="HinhAnh" class="form-label fw-semibold">Ảnh sản phẩm</label>
                            <div class="row align-items-center">
                                <div class="col-md-9">
                                    <div class="input-group">
                                        <span class="input-group-text bg-light"><i class="bi bi-image"></i></span>
                                        <input type="file" class="form-control" id="HinhAnh" name="HinhAnh" accept="image/*">
                                    </div>
                                    <div class="form-text mt-1">Chọn tệp hình ảnh để tải lên (Để trống sẽ giữ nguyên ảnh hiện tại).</div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <img src="<%= dienthoai.HinhAnh ? (dienthoai.HinhAnh.startsWith('http') || dienthoai.HinhAnh.startsWith('/') ? dienthoai.HinhAnh : '/images/products/' + dienthoai.HinhAnh) : '/images/icons/product.jpg' %>" id="img-preview" class="preview-img mt-2 mt-md-0 shadow-sm" alt="Preview">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 text-start">
                            <label for="LuotXem" class="form-label fw-semibold">Lượt xem</label>
                            <input type="number" class="form-control" id="LuotXem" name="LuotXem" value="<%= dienthoai.LuotXem %>" min="0">
                        </div>

                        <div class="col-md-6 text-start">
                            <label for="LuotMua" class="form-label fw-semibold">Lượt mua</label>
                            <input type="number" class="form-control" id="LuotMua" name="LuotMua" value="<%= dienthoai.LuotMua %>" min="0">
                        </div>

                        <div class="col-md-12 text-start">
                            <label for="MoTa" class="form-label fw-semibold">Mô tả sản phẩm</label>
                            <textarea class="form-control" id="MoTa" name="MoTa" rows="6"><%= dienthoai.MoTa %></textarea>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/dienthoai" class="btn btn-light px-4">Quay lại</a>
                        <button type="submit" class="btn btn-warning px-5 shadow-sm text-dark fw-bold">
                            <i class="bi bi-save2 me-2"></i>Cập nhật thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer Section -->
    <%- include('footer') %>

    <!-- Javascript Section -->
    <%- include('javascript') %>

    <script>
        (() => {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
            
            // Xử lý xem trước ảnh khi thay đổi URL
            const hinhAnhInput = document.getElementById('HinhAnh');
            const imgPreview = document.getElementById('img-preview');
            if (hinhAnhInput && imgPreview) {
                hinhAnhInput.addEventListener('change', function() {
                    const file = this.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            imgPreview.src = e.target.result;
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }
        })();
    </script>
</body>

</html>
