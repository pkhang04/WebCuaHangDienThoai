<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - MobiStore
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

    <!-- Navbar Section -->
    <%- include('navbar') %>

        <!-- Notification -->
        <div class="container mt-3">
            <%- message %>
        </div>

        <div class="container main-content mt-4 mb-5">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item">
                        <a href="/timkiem?q=<%= sanpham.DanhMuc ? sanpham.DanhMuc.TenDanhMuc : '' %>">
                            <%= sanpham.DanhMuc ? sanpham.DanhMuc.TenDanhMuc : 'Sản phẩm' %>
                        </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        <%= sanpham.TenDT %>
                    </li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0 mt-3 p-4">
                <div class="row g-5">
                    <!-- Product Image -->
                    <div class="col-md-5 text-center position-relative">
                        <div class="bg-white rounded-3 p-4 mb-3 border d-flex align-items-center justify-content-center"
                            style="height: 400px;">
                            <img src="<%= sanpham.HinhAnh ? (sanpham.HinhAnh.startsWith('http') || sanpham.HinhAnh.startsWith('/') ? sanpham.HinhAnh : '/images/products/' + sanpham.HinhAnh) : '/images/icons/product.jpg' %>"
                                class="img-fluid" alt="<%= sanpham.TenDT %>"
                                style="max-height: 100%; object-fit: contain;">
                        </div>
                        <% if (sanpham.GiaGoc> sanpham.GiaBan) {
                            const percent = Math.round(((sanpham.GiaGoc - sanpham.GiaBan) / sanpham.GiaGoc) * 100);
                            %>
                            <span class="position-absolute shadow-sm"
                                style="top: 20px; left: 20px; background-color: #dc3545; color: white; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 14px;">Giảm
                                <%= percent %>%
                            </span>
                            <% } %>
                    </div>

                    <!-- Product Details -->
                    <div class="col-md-7">
                        <h1 class="fw-bold mb-3">
                            <%= sanpham.TenDT %>
                        </h1>

                        <div class="d-flex align-items-center gap-4 mb-4">
                            <div class="text-warning">
                                <% let totalStars=0; let avgStars=0; if (danhgias && danhgias.length> 0) {
                                    totalStars = danhgias.reduce((sum, dg) => sum + dg.SoSao, 0);
                                    avgStars = (totalStars / danhgias.length).toFixed(1);
                                    }
                                    for(let i = 1; i <= 5; i++) { if (i <=Math.floor(avgStars)) { %>
                                        <i class="bi bi-star-fill"></i>
                                        <% } else if (i===Math.ceil(avgStars) && avgStars % 1 !==0) { %>
                                            <i class="bi bi-star-half"></i>
                                            <% } else { %>
                                                <i class="bi bi-star"></i>
                                                <% } } %>
                                                    <span class="text-muted ms-1 fs-6">(<%= danhgias.length %> đánh
                                                            giá)</span>
                            </div>
                            <div class="text-muted">
                                <i class="bi bi-eye me-1"></i>
                                <%= sanpham.LuotXem %> lượt xem
                            </div>
                            <div class="text-muted">
                                <i class="bi bi-cart-check me-1"></i>
                                <%= sanpham.LuotMua %> đã bán
                            </div>
                        </div>

                        <div class="bg-light p-4 rounded-3 mb-4 border border-1 border-primary-subtle">
                            <div class="d-flex align-items-end gap-3">
                                <span class="text-danger fw-bold display-6 price-text">
                                    <%= sanpham.GiaBan.toLocaleString('vi-VN') %>đ
                                </span>
                                <% if (sanpham.GiaGoc> sanpham.GiaBan) { %>
                                    <span class="text-decoration-line-through text-muted fs-5">
                                        <%= sanpham.GiaGoc.toLocaleString('vi-VN') %>đ
                                    </span>
                                    <% } %>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold mb-2">Tình trạng:</h6>
                            <% if (sanpham.SoLuong> 0) { %>
                                <span
                                    class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-6">
                                    <i class="bi bi-check-circle-fill me-2"></i>Còn <%= sanpham.SoLuong %> sản phẩm
                                </span>
                                <% } else { %>
                                    <span
                                        class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 fs-6">
                                        <i class="bi bi-x-circle-fill me-2"></i>Tạm hết hàng
                                    </span>
                                    <% } %>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold mb-2">Mô tả sản phẩm:</h6>
                            <div class="text-muted" style="line-height: 1.8;">
                                <%= sanpham.MoTa || 'Đang cập nhật mô tả chi tiết cho sản phẩm này.' %>
                            </div>
                        </div>

                        <hr class="my-4">

                        <form action="/giohang/them/<%= sanpham._id %>" method="POST" class="d-flex gap-3">
                            <div class="input-group" style="width: 130px;">
                                <button class="btn btn-outline-secondary" type="button"
                                    onclick="this.parentNode.querySelector('input[type=number]').stepDown()">-</button>
                                <input type="number" class="form-control text-center px-1" name="SoLuong" value="1"
                                    min="1" max="<%= sanpham.SoLuong > 0 ? sanpham.SoLuong : 1 %>">
                                <button class="btn btn-outline-secondary" type="button"
                                    onclick="this.parentNode.querySelector('input[type=number]').stepUp()">+</button>
                            </div>
                            <% if (sanpham.SoLuong> 0) { %>
                                <button type="submit"
                                    class="btn btn-primary flex-fill fw-bold py-2 fs-5 text-uppercase">
                                    Thêm vào giỏ hàng
                                </button>
                                <% } else { %>
                                    <button type="button"
                                        class="btn btn-secondary flex-fill fw-bold py-2 fs-5 text-uppercase" disabled>
                                        Đã hết hàng
                                    </button>
                                    <% } %>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Reviews Section -->
            <div class="card shadow-sm border-0 mt-5 p-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2"></i>Đánh giá từ khách hàng</h4>

                <% if (danhgias && danhgias.length> 0) { %>
                    <div class="row">
                        <% danhgias.forEach(dg=> {
                            if (dg.HienThi) { %>
                            <div class="col-12 mb-4 pb-4 border-bottom last-child-border-0">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                            style="width: 45px; height: 45px;">
                                            <i class="bi bi-person fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">
                                                <%= dg.NguoiDung ? dg.NguoiDung.HoVaTen : 'Người dùng ẩn danh' %>
                                            </h6>
                                            <small class="text-muted">
                                                <%= dg.NgayDanhGia.toLocaleDateString('vi-VN', {day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %>
                                            </small>
                                        </div>
                                    </div>
                                    <div class="text-warning fs-5">
                                        <% for(let i=1; i <=5; i++) { %>
                                            <i class="bi bi-star<%= i <= dg.SoSao ? '-fill' : '' %>"></i>
                                            <% } %>
                                    </div>
                                </div>
                                <p class="mt-2 mb-2 text-dark">
                                    <%= dg.NoiDung %>
                                </p>

                                <% if (dg.PhanHoi && dg.PhanHoi.length> 0) { %>
                                    <% dg.PhanHoi.forEach(ph=> { %>
                                        <div
                                            class="ms-5 mt-3 p-3 bg-light rounded-3 border-start border-4 border-warning shadow-sm mb-2">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-patch-check-fill text-warning me-2"></i>
                                                    <span class="fw-bold small text-dark">MobiStore phản hồi</span>
                                                </div>
                                                <small class="text-muted" style="font-size: 0.75rem;">
                                                    <%= ph.NgayPhanHoi.toLocaleDateString('vi-VN', {hour: '2-digit' ,
                                                        minute:'2-digit'}) %>
                                                </small>
                                            </div>
                                            <p class="mb-0 small text-muted">
                                                <%= ph.NoiDung %>
                                            </p>
                                        </div>
                                        <% }) %>
                                            <% } %>
                            </div>
                            <% } }) %>
                    </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="bi bi-chat-square-dots fs-1 text-muted opacity-25 d-block mb-3"></i>
                            <p class="text-muted">Chưa có đánh giá nào cho sản phẩm này.</p>
                        </div>
                        <% } %>
            </div>
        </div>

        <!-- Footer Section -->
        <%- include('footer') %>

            <!-- Javascript Section -->
            <%- include('javascript') %>
</body>

<style>
    .last-child-border-0:last-child {
        border-bottom: 0 !important;
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }
</style>

</html>